# Optional: copy to `.env` in this directory. Docker Compose loads it when present.
# Do not commit real secrets.

# Persistent Chrome user-data dir inside the container (optional).
# IGSCRAPER_CHROME_PROFILE=/tmp/chrome-profile

# Google Cloud credentials path *inside* the container when you mount a key file.
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcs-sa.json
